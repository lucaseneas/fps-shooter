{
  "name": "fps-shooter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FPS Web 3D (Mata-Mata) - cliente Babylon.js",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch --tsconfig server/tsconfig.json server/index.ts",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@babylonjs/core": "^7.0.0",
    "@babylonjs/materials": "^7.54.3",
    "colyseus": "^0.15.57",
    "colyseus.js": "^0.15.28"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
